{
    "name": "Watch Together",
    "version": "0.3",
    "manifest_version": 3,
    "description": "Synchronized video controlling using WebRTC.",
    "permissions": [
        "storage",
        "activeTab",
        "scripting",
        "offscreen"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background-sw.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "32": "images/icon32.png",
            "64": "images/icon64.png",
            "128": "images/icon128.png"
        }
    },
    "icons": {
        "32": "images/icon32.png",
        "64": "images/icon64.png",
        "128": "images/icon128.png"
    }
}
